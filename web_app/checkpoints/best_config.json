{
  "seed": 42,
  "model": {
    "name": "unet",
    "encoder_name": "resnet34",
    "encoder_weights": "imagenet",
    "decoder_channels": [
      256,
      128,
      64,
      32,
      16
    ],
    "decoder_attention_type": "scse",
    "in_channels": 3,
    "classes": 1
  },
  "training": {
    "batch_size": 32,
    "find_unused_parameters": true,
    "max_epochs": 500,
    "optimizer": "adamw",
    "lr": 0.0002,
    "weight_decay": 0.0001,
    "mixed_precision": true,
    "grad_clip": null,
    "deterministic": false,
    "differential_lr": {
      "enabled": false,
      "encoder_lr_scale": 0.1
    },
    "loss": {
      "focal_weight": 0.5,
      "dice_weight": 0.5,
      "focal_gamma": 2.0,
      "focal_alpha": null
    }
  },
  "lr_schedule": {
    "scheduler": "reduce_on_plateau",
    "monitor": "val_dice",
    "mode": "max",
    "factor": 0.5,
    "patience": 5,
    "min_lr": 1e-07,
    "warmup_epochs": 0,
    "warmup_start_lr": 1e-06
  },
  "early_stopping": {
    "patience": 10,
    "min_delta": 0.0001,
    "monitor": "val_dice",
    "mode": "max"
  },
  "data": {
    "root": "data/processed",
    "input_size": [
      256,
      256
    ],
    "num_workers": 4,
    "pin_memory": true,
    "persistent_workers": true,
    "val_batch_size_multiplier": 2
  },
  "logging": {
    "use_wandb": true,
    "project": "Skin-Lesion-Segmentation",
    "entity": null,
    "experiment_name": "resnet34_unet_kaggle_t4",
    "use_dagshub": false,
    "dagshub_username": null,
    "dagshub_repo": null,
    "upload_model": false
  },
  "output": {
    "dir": "outputs"
  }
}